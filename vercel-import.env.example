# Template for Vercel → Settings → Environment Variables → Import .env file
#
# 1. Copy this file:  cp vercel-import.env.example vercel-import.env
# 2. Replace every placeholder (paste Neon URL, generate secrets — see below).
# 3. Set AUTH_URL / NEXTAUTH_URL to your real URL (e.g. https://your-app.vercel.app).
# 4. In Vercel: Import `vercel-import.env` for Production (and Preview if you want).
#
# Generate secrets in Terminal:
#   openssl rand -base64 32    → AUTH_SECRET
#   openssl rand -hex 32       → ENCRYPTION_KEY
#   openssl rand -hex 32       → CRON_SECRET (or any long random string)
#
# `vercel-import.env` is gitignored — do not commit it.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

AUTH_SECRET="REPLACE_WITH_openssl_rand_base64_32"
AUTH_URL="https://YOUR-PROJECT-NAME.vercel.app"
NEXTAUTH_URL="https://YOUR-PROJECT-NAME.vercel.app"

ENCRYPTION_KEY="REPLACE_WITH_openssl_rand_hex_32"
CRON_SECRET="REPLACE_WITH_RANDOM_STRING"
RESEND_API_KEY="re_REPLACE_WITH_RESEND_KEY"

# Optional — social OAuth (omit or leave empty until you configure platforms)
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
META_APP_ID=""
META_APP_SECRET=""
