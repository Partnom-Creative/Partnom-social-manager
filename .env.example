# Use sslmode=verify-full for TLS (avoids pg v8 "sslmode=require" deprecation warning in dev).
# If your host requires libpq semantics instead, use: ?uselibpqcompat=true&sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/social_hub?sslmode=verify-full"

# Auth.js / NextAuth — required for sessions & sign-in (use either AUTH_* or NEXTAUTH_*)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Public origin (no trailing slash). In production set AUTH_URL and NEXTAUTH_URL to the same https URL.
AUTH_URL="http://localhost:3000"
# Legacy names (still supported):
# NEXTAUTH_SECRET="same-as-AUTH_SECRET"
NEXTAUTH_URL="http://localhost:3000"
# Vercel sets VERCEL_URL automatically; getPublicBaseUrl() uses it if AUTH_* unset (preview deploys).

ENCRYPTION_KEY="generate-64-char-hex-key-with-openssl-rand-hex-32"

RESEND_API_KEY="re_your_resend_api_key"
# Optional. For production you should verify a sending domain in Resend and set a from address on that domain.
# Example: RESEND_FROM="Social Hub <no-reply@yourdomain.com>"
RESEND_FROM="Social Hub <onboarding@resend.dev>"

TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""

LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

META_APP_ID=""
META_APP_SECRET=""
